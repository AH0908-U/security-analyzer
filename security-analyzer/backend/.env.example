# Security Analyzer Backend
# Copy this to .env and fill in your API keys

# App
DEBUG=false
FRONTEND_URL=http://localhost:3000

# Database (SQLite for dev, PostgreSQL in production)
DATABASE_URL=sqlite+aiosqlite:///./security_analyzer.db

# External API Keys (optional - leave blank to use built-in checks only)
PHISHTANK_API_KEY=
VIRUSTOTAL_API_KEY=
HIBP_API_KEY=
GOOGLE_SAFE_BROWSING_API_KEY=
